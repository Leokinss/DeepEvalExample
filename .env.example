# DeepEval uses OpenAI by default as the LLM judge for its metrics.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# I am personally using Gemini as my model for evaluation, so I have the following variables set. You can change these to use a different model or provider.
EVAL_MODEL=gemini-3.5-flash
GEMINI_API_KEY=...